{
  "name": "browserapiextended-electron-wasm-goobercss",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "VITE_NO_ELECTRON=1 vite",
    "dev:electron": "vite",
    "build:wasm": "cd src/wasm && wasm-pack build --target web",
    "build": "tsc && vite build && electron-builder",
    "build:win": "tsc && vite build && electron-builder --win",
    "run:win": "wine \"release/$npm_package_version/YourAppName-Windows-$npm_package_version-Portable.exe\"",
    "preview": "vite preview",
    "test:frontend": "vitest run",
    "docs:gen": "cd tools/docs && npm run build",
    "docs:serve": "bun x serve api-docs-dist",
    "docs:dev": "cd tools/docs && npm run dev"
  },
  "devDependencies": {
    "@types/cytoscape": "^3.21.9",
    "@types/leaflet": "^1.9.21",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "jsdom": "^29.1.1",
    "tsx": "^4.22.4",
    "typescript": "^5.2.2",
    "vite": "^5.1.6",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vitest": "^4.1.8"
  },
  "main": "dist-electron/main.js",
  "dependencies": {
    "@sqlite.org/sqlite-wasm": "^3.53.0-build1",
    "@turf/turf": "^7.3.5",
    "clsx": "^2.1.1",
    "cytoscape": "^3.34.0",
    "goober": "^2.1.19",
    "leaflet": "^1.9.4",
    "sql.js": "^1.11.0",
    "vega": "^6.2.0",
    "vega-embed": "^7.1.0",
    "vega-lite": "^6.4.3",
    "vis-network": "^10.1.0",
    "zod": "^4.4.3"
  }
}
